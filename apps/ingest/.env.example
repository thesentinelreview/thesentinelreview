# PostgreSQL — same DB as the web app
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sentinel

# Anthropic — entity extraction (Sonnet) and briefing (Opus)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_EXTRACT=claude-sonnet-4-6
ANTHROPIC_MODEL_BRIEFING=claude-opus-4-7

# Telegram (optional — skip if not ingesting Telegram)
# Register at https://my.telegram.org to get api_id and api_hash
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=sentinel_session

# X / Twitter (optional — skip if not ingesting X)
X_BEARER_TOKEN=

# Worker tuning (defaults are fine for v0.1)
WORKER_POLL_INTERVAL=5
WORKER_BATCH_SIZE=10

# Logging: INFO or DEBUG
LOG_LEVEL=INFO

# Integrity alerts — optional Slack incoming webhook URL.
# When set, sentinel-run-checks POSTs a Slack message on any critical failure.
# Create at: https://api.slack.com/messaging/webhooks
SENTINEL_ALERT_WEBHOOK_URL=
