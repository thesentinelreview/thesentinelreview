# Postgres connection string. When unset, the web app falls back to
# placeholder seed data (useful for local dev without a database running).
#
# Format: postgres://USER:PASS@HOST:PORT/DBNAME
# Supabase, Neon, and any standard Postgres provider work.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sentinel

# Public site URL — used in embed code copy-paste output. Optional.
NEXT_PUBLIC_SITE_URL=https://thesentinelreview.com
