# Postgres connection string. When unset, the web app falls back to
# placeholder seed data (useful for local dev without a database running).
#
# Supabase session-mode pooler (use for Vercel/Next.js deployments):
# DATABASE_URL=postgresql://postgres.ugpqgfvdqupttqhogavc:[PASSWORD]@aws-0-eu-west-2.pooler.supabase.com:5432/postgres
#
# Local dev:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sentinel

# Public site URL — used for Stripe checkout success/cancel redirects and in
# embed code copy-paste output. Must be the dashboard origin (where /api/activate
# lives), not the static marketing site.
NEXT_PUBLIC_SITE_URL=https://dashboard.thesentinelreview.com

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect URLs (set in Vercel env, not in ClerkProvider props)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Analyst monthly price slot. During the founding window this holds the founding
# price; at 250 seats it swaps to the standard price (W1-1 runbook, 2026-06-10).
NEXT_PUBLIC_STRIPE_ANALYST_PRICE_MONTHLY=price_...

# Founding price ID (server-side). Stays constant after the window swap — drives
# is_founding derivation and the 250-seat cap guard in /api/checkout.
STRIPE_FOUNDING_PRICE_ID=price_...

# Yearly is DELIBERATELY unset — annual billing is cut (W1-1 runbook, 2026-06-10).
# The checkout CTAs are env-conditional: unset means the button doesn't render.
# NEXT_PUBLIC_STRIPE_ANALYST_PRICE_YEARLY=price_...

# Bureau tier is "coming soon" — leave unset until launch.
# NEXT_PUBLIC_STRIPE_BUREAU_PRICE_MONTHLY=price_...
# NEXT_PUBLIC_STRIPE_BUREAU_PRICE_YEARLY=price_...
