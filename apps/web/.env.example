# Postgres connection string. When unset, the web app falls back to
# placeholder seed data (useful for local dev without a database running).
#
# Format: postgres://USER:PASS@HOST:PORT/DBNAME
# Supabase, Neon, and any standard Postgres provider work.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sentinel

# Public site URL — used in embed code copy-paste output. Optional.
NEXT_PUBLIC_SITE_URL=https://thesentinelreview.com

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# Clerk redirect URLs (set in Vercel env, not in ClerkProvider props)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_ANALYST_MONTHLY_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_ANALYST_YEARLY_PRICE_ID=price_...
